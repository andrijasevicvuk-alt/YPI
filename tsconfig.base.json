{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@ypi/domain": ["packages/domain/src/index.ts"],
      "@ypi/data-access": ["packages/data-access/src/index.ts"],
      "@ypi/scoring": ["packages/scoring/src/index.ts"]
    }
  }
}
